<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="New TestNG Suite" parallel="methods" thread-count="4">
    <listeners>
            <listener class-name="oop.testng.listeners.TestListener"/>
    </listeners>

    <test name="Login Tests">
        <classes>
            <class name="oop.testng.LoginTestNG"/>
        </classes>
    </test>

    <test name="AdvancedInteractions">
            <classes>
                    <class name="ui.advanced.ActionsTest"/>
                    <class name="ui.advanced.JSExecutorTest"/>
                    <class name="ui.advanced.ShadowDomTest"/>
            </classes>
    </test>

    <test name="API">
        <classes>
            <class name="api.UsersApiTest"/>
        </classes>
    </test>
</suite>